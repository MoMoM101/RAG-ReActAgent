# ── LLM ────────────────────────────────────────────
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o
LLM_BASE_URL=https://api.openai.com/v1
# DeepSeek V4 only: false avoids long pre-answer reasoning for routine RAG.
LLM_THINKING_ENABLED=false
LLM_API_KEY=
LLM_MAX_CONTEXT=0
LLM_OUTPUT_TOKEN_RESERVE=4096
LLM_REASONING_TOKEN_RESERVE=0
CONTEXT_SAFETY_TOKENS=2048
CONTEXT_TOOL_RESULT_MAX_TOKENS=800
CONTEXT_SUMMARY_MAX_TOKENS=512
CONTEXT_SUMMARY_MAX_ITEMS=20
MEMORY_EXTRACT_MAX_TOKENS=2048
MEMORY_EXTRACT_DEBOUNCE_SECONDS=2
MIGRATION_BACKUP_KEEP=5
TOKENIZER_PROVIDER=auto
TOKENIZER_MODEL=
TOKENIZER_FALLBACK_SAFETY_FACTOR=1.15
LLM_STREAM_USAGE_ENABLED=true

# ── Embedding ──────────────────────────────────────
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_API_KEY=
EMBEDDING_DIM=1536

# ── Vector Database (Qdrant) ──────────────────────
QDRANT_HOST=
QDRANT_PORT=6333
QDRANT_PATH=./data/qdrant2
QDRANT_COLLECTION=rag_chunks
QDRANT_ACTIVE_COLLECTION=

# ── SQLite ─────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./data/rag_agent.db

# ── Storage ────────────────────────────────────────
UPLOAD_DIR=./data/uploads
DOCUMENT_MAX_UPLOAD_MB=200
DOCUMENT_BATCH_MAX_FILES=50
DOCUMENT_BATCH_MAX_TOTAL_MB=1024

# ── Agent ──────────────────────────────────────────
MAX_LOOP_ITERATIONS=10
MAX_TOOL_RETRIES=3
MAX_TOTAL_TIME=120

# ── Timeouts ───────────────────────────────────────
LLM_CONNECT_TIMEOUT=10.0
LLM_READ_TIMEOUT=60.0
LLM_FIRST_TOKEN_TIMEOUT=30.0
TOOL_DEFAULT_TIMEOUT=30.0
EMBEDDING_TIMEOUT=30.0

# ── LLM Retry ──────────────────────────────────────
LLM_MAX_RETRIES=3
LLM_RETRY_BACKOFF=1.0

# ── Chunking ───────────────────────────────────────
CHUNK_SIZE=200
CHUNK_OVERLAP=40
RETRIEVAL_TOP_K=8

# ── Retrieval Dedup ────────────────────────────────
DEDUP_ENABLED=true
DEDUP_SIMILARITY_THRESHOLD=0.85

# ── Reranker (optional, requires pip install -r requirements-rerank.txt) ──
RERANK_ENABLED=false
RERANK_MODEL=BAAI/bge-reranker-v2-m3
RERANK_TOP_N=16
RRF_K=60
RRF_SEMANTIC_WEIGHT=2.0
RRF_KEYWORD_WEIGHT=1.0
RRF_QUALITY_PREFILTER_ENABLED=false
RRF_ADAPTIVE_ENABLED=false
HF_ENDPOINT=
CHUNK_QUALITY_FILTER_ENABLED=true
CHUNK_QUALITY_LLM_ENABLED=false
QUERY_REWRITE_ENABLED=true
QUERY_REWRITE_DISAMBIGUATION_ONLY=true
GROUNDING_VERIFICATION_ENABLED=true
GROUNDING_MIN_COVERAGE=0.70
GROUNDING_COVERAGE_RECHECK_ENABLED=true
GROUNDING_ENFORCEMENT=report

# ── V4 Grounding repair ────────────────────────────────
GROUNDING_STREAM_VERIFY_ENABLED=false
GROUNDING_DETERMINISTIC_REPAIR_ENABLED=true
GROUNDING_AUTO_CITE_MIN_SCORE=0.55
GROUNDING_AUTO_CITE_MIN_MARGIN=0.15
GROUNDING_REPAIR_ENABLED=true
GROUNDING_REPAIR_MODEL=
GROUNDING_REPAIR_TIMEOUT=4
GROUNDING_REPAIR_MAX_TOKENS=350
GROUNDING_REPAIR_MAX_ATTEMPTS=1

# ── V4 Answer cache ────────────────────────────────────
RAG_ANSWER_CACHE_ENABLED=false
RAG_ANSWER_CACHE_TTL_SECONDS=300
RAG_ANSWER_CACHE_MAX_ENTRIES=1000

# ── V4 Output budget ──────────────────────────────────
RAG_GENERATION_MAX_TOKENS=0
RAG_TRUNCATION_RECOVERY_ENABLED=true
RAG_TRUNCATION_RECOVERY_MAX_TOKENS=2048

# ── V4 Phase-level timeout budgets (0=unlimited) ──
RAG_TIMEOUT_INTENT=5.0
RAG_TIMEOUT_RETRIEVAL=10.0
RAG_TIMEOUT_RERANK=5.0
RAG_TIMEOUT_GENERATION=60.0
RAG_TIMEOUT_VERIFICATION=5.0
RAG_TIMEOUT_REPAIR=10.0

# ── V4 Performance gates ──────────────────────────────
RAG_TTFT_P95_TARGET_MS=2500
RAG_TOTAL_P95_TARGET_MS=5000

# ── Web Search (optional) ──────────────────────────
WEB_SEARCH_ENABLED=false
WEB_SEARCH_MAX_RESULTS=5
WEB_SEARCH_PROXY=

# ── OCR (optional, requires pip install -r requirements-ocr.txt) ──
OCR_ENABLED=false
OPTIONAL_MODEL_NOTICE_SECONDS=180
OPTIONAL_MODEL_POLL_SECONDS=5
OCR_MIN_TEXT_LENGTH=50

# ── Memory ─────────────────────────────────────────
MEMORY_ENABLED=true
MEMORY_MAX_COUNT=100

# ── Ingestion ──────────────────────────────────────
INGESTION_MAX_CONCURRENCY=3
INGESTION_MAX_RETRIES=3
INGESTION_RETRY_BASE_SEC=5.0
INGESTION_RETRY_MAX_SEC=300.0
INGESTION_RETRY_JITTER=0.3

# ── Development ────────────────────────────────────
# Set true for first run to auto-create database tables without manual alembic.
AUTO_MIGRATE=true

# ── Logging ────────────────────────────────────────
LOG_LEVEL=INFO

# ── Server ─────────────────────────────────────────
SECRET_KEY=
SERVER_HOST=127.0.0.1
ALLOW_REMOTE_ACCESS=false

# ── Authentication ─────────────────────────────────
# JWT_SECRET is auto-generated on first startup if empty or < 32 chars.
# Set a stable value here only if you need to share tokens across instances.
JWT_SECRET=
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
# Set true behind HTTPS in production. Keep false for local HTTP development.
AUTH_COOKIE_SECURE=false
# ⚠️ First-run admin account (only used when the users table is empty):
# Leave BOOTSTRAP_ADMIN_PASSWORD empty to auto-generate one on first startup.
# The generated password is saved to .env and printed to the console.
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=

# ── Backup / Restore ──────────────────────────────
BACKUP_MAX_UPLOAD_MB=512
BACKUP_MAX_EXTRACTED_MB=2048
BACKUP_MAX_MEMBERS=10000
